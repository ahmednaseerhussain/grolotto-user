{
  "expo": {
    "name": "GroLotto",
    "slug": "grolotto",
    "scheme": "grolotto",
    "version": "1.0.0",
    "sdkVersion": "51.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.grolotto.app"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69fce7b6-ab77-4dfb-b626-8a0b19138341"
      }
    }
  }
}
